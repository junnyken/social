# ═══════════════════════════════════════════════════════════════
# SocialHub v2.0 — Production Environment Variables
# ═══════════════════════════════════════════════════════════════

# Server
NODE_ENV=production
PORT=3000

# Facebook App
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret

# AI Engine (Gemini)
GEMINI_API_KEY=your_gemini_api_key

# Security
ENCRYPTION_KEY=generate_a_64_char_hex_string_for_production
JWT_SECRET=generate_a_secure_random_jwt_secret
SESSION_SECRET=generate_a_secure_session_secret

# CORS (comma-separated production domains)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=warn
